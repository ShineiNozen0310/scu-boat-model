{
  "terminal.integrated.profiles.windows": {
    "MSYS2 UCRT64": {
      "path": "C:\\msys64\\usr\\bin\\bash.exe",
      "args": [
        "--login",
        "-i"
      ],
      "env": {
        "MSYSTEM": "UCRT64",
        "CHERE_INVOKING": "1"
      }
    }
  },
  "terminal.integrated.defaultProfile.windows": "MSYS2 UCRT64",
  "C_Cpp.default.compilerPath": "C:/msys64/ucrt64/bin/gcc.exe",
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/firmware/cubemx",
    "${workspaceFolder}/firmware/app",
    "${workspaceFolder}/firmware/app/control",
    "${workspaceFolder}/firmware/app/drivers",
    "${workspaceFolder}/firmware/app/safety"
  ],
  "C_Cpp.default.intelliSenseMode": "windows-gcc-x64",
  "C_Cpp.errorSquiggles": "enabled",
  "files.associations": {
    "*.h": "c"
  }
}
