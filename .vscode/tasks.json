{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build firmware template",
      "type": "shell",
      "command": "C:\\msys64\\ucrt64\\bin\\gcc.exe",
      "args": [
        "-std=c11",
        "-g",
        "-Wall",
        "-Wextra",
        "-Wpedantic",
        "-I",
        "firmware/include",
        "firmware/src/main.c",
        "firmware/src/ir_capture_queue.c",
        "firmware/src/boat_ir_decoder.c",
        "firmware/src/boat_controller.c",
        "-o",
        "boat-template.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:\\msys64\\ucrt64\\bin;${env:PATH}"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}
